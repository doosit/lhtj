[Rewrite]
http-request ^https?:\/\/gw2c\-hw\-open\.longfor\.com\/lmarketing\-task\-api\-mvc\-prod\/openapi\/task\/v1\/signature\/clock script-path=https://raw.githubusercontent.com/doosit/lhtj/main/lhtj.js, requires-body=0, timeout=60, tag=龙湖天街获取Cookie

[Script]
cron "4 7 * * *" script-path=https://raw.githubusercontent.com/doosit/lhtj/main/lhtj.js, timeout=60, tag=龙湖天街签到抽奖

[MITM]
hostname = gw2c-hw-open.longfor.com
