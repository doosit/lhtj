[script]
http-request ^https?:\/\/gw2c\-hw\-open\.longfor\.com\/(?:lmarketing\-task\-api\-mvc\-prod\/openapi\/task\/v1\/(?:signature\/clock|lottery\/(?:sign|luck))|llt\-gateway\-prod\/api\/v1\/activity\/auth\/lottery\/(?:sign|click)) script-path=https://raw.githubusercontent.com/doosit/lhtj/main/lhtj.js, requires-body=false, timeout=60, tag=龙湖天街获取Cookie
cron "4 7 * * *" script-path=https://raw.githubusercontent.com/doosit/lhtj/main/lhtj.js, timeout=60, tag=龙湖天街签到抽奖

[mitm]
